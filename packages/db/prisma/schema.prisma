/// PO lifecycle: draft → submitted → approved → issued → delivered → closed
/// Approved+ (committed_cost): approved, issued, partially_delivered, delivered, closed
enum PurchaseOrderStatus {
  draft               @map("draft")
  submitted           @map("submitted")
  approved            @map("approved")
  issued              @map("issued")
  partially_delivered @map("partially_delivered")
  delivered           @map("delivered")
  closed              @map("closed")
  rejected            @map("rejected")
  cancelled           @map("cancelled")
  returned            @map("returned")

  @@map("purchase_order_status")
}

/// SI lifecycle: received → under_review → approved → paid → closed
/// Approved+ (actual_cost): approved, paid, closed
enum SupplierInvoiceStatus {
  received     @map("received")
  under_review @map("under_review")
  approved     @map("approved")
  disputed     @map("disputed")
  paid         @map("paid")
  closed       @map("closed")
  rejected     @map("rejected")

  @@map("supplier_invoice_status")
}

/// Expense lifecycle: draft → submitted → approved → paid → closed
/// Approved+ (actual_cost): approved, paid, closed
enum ExpenseStatus {
  draft     @map("draft")
  submitted @map("submitted")
  approved  @map("approved")
  paid      @map("paid")
  closed    @map("closed")
  rejected  @map("rejected")
  cancelled @map("cancelled")

  @@map("expense_status")
}

/// CN lifecycle: received → verified → applied → closed
enum CreditNoteStatus {
  received  @map("received")
  verified  @map("verified")
  applied   @map("applied")
  disputed  @map("disputed")
  closed    @map("closed")
  cancelled @map("cancelled")

  @@map("credit_note_status")
}

// ---------------------------------------------------------------------------
// Enums — Internal Budget & EI
// ---------------------------------------------------------------------------

enum BudgetAdjustmentType {
  baseline_change        @map("baseline_change")
  contingency_change     @map("contingency_change")
  ei_reserve_change      @map("ei_reserve_change")
  reallocation           @map("reallocation")
  line_import            @map("line_import")
  line_manual_adjustment @map("line_manual_adjustment")

  @@map("budget_adjustment_type")
}

/// EI lifecycle: received → under_evaluation → approved_reserve → converted/rejected/expired
enum EiStatus {
  received         @map("received")
  under_evaluation @map("under_evaluation")
  approved_reserve @map("approved_reserve")
  converted        @map("converted")
  rejected         @map("rejected")
  expired          @map("expired")

  @@map("ei_status")
}

// ---------------------------------------------------------------------------
// Module 4: Internal Budget Control
//
// Internal budget is SEPARATE from external contract value.
// Contract value = what the client pays Pico Play.
// Internal budget = what Pico Play allocates to deliver the project.
//
// remainingBudget = internalRevised - SUM(budgetLine.committedAmount)
// This is against committed, not actual, because committed represents
// obligations already placed (POs, subcontracts) while actual represents
// payments already made. Committed is the conservative control metric.
// ---------------------------------------------------------------------------

model BudgetCategory {
  id        String   @id @default(uuid()) @map("id")
  code      String   @unique @map("code")
  name      String   @map("name")
  sortOrder Int      @default(0) @map("sort_order")
  isSystem  Boolean  @default(false) @map("is_system")
  createdAt DateTime @default(now()) @map("created_at")

  lines BudgetLine[]

  @@map("budget_categories")
}

/// One budget header per project. Stores the internal delivery baseline
/// which is distinct from the external contract value on the Project model.
model ProjectBudget {
  id                String   @id @default(uuid()) @map("id")
  projectId         String   @unique @map("project_id")
  internalBaseline  Decimal  @map("internal_baseline") @db.Decimal(18, 2)
  internalRevised   Decimal  @map("internal_revised") @db.Decimal(18, 2)
  contingencyAmount Decimal  @default(0) @map("contingency_amount") @db.Decimal(18, 2)
  eiReserveTotal    Decimal  @default(0) @map("ei_reserve_total") @db.Decimal(18, 2)
  notes             String?  @map("notes")
  createdBy         String   @map("created_by")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  project     Project            @relation(fields: [projectId], references: [id], onDelete: Restrict)
  lines       BudgetLine[]
  adjustments BudgetAdjustment[]

  @@map("project_budgets")
}

/// Per-category budget allocation within a project.
/// committedAmount = sum of obligations placed (POs, subcontracts).
/// actualAmount = sum of payments made (supplier invoices, expenses).
/// remainingAmount (derived) = budgetAmount - committedAmount.
/// varianceAmount (derived) = budgetAmount - actualAmount.
model BudgetLine {
  id              String   @id @default(uuid()) @map("id")
  budgetId        String   @map("budget_id")
  categoryId      String   @map("category_id")
  budgetAmount    Decimal  @default(0) @map("budget_amount") @db.Decimal(18, 2)
  committedAmount Decimal  @default(0) @map("committed_amount") @db.Decimal(18, 2)
  actualAmount    Decimal  @default(0) @map("actual_amount") @db.Decimal(18, 2)
  notes           String?  @map("notes")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Import provenance — set when this line was last written via an import commit.
  // lastImportedAmount is the preserved "what the sheet said" value and is NOT
  // mutated by subsequent manual adjustments — UI keeps showing imported vs current.
  importBatchId      String?   @map("import_batch_id")
  importRowId        String?   @map("import_row_id")
  lastImportedAmount Decimal?  @map("last_imported_amount") @db.Decimal(18, 2)
  importedByUserId   String?   @map("imported_by_user_id")
  importedAt         DateTime? @map("imported_at")

  budget      ProjectBudget      @relation(fields: [budgetId], references: [id], onDelete: Restrict)
  category    BudgetCategory     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  adjustments BudgetAdjustment[]

  @@unique([budgetId, categoryId])
  @@index([budgetId])
  @@map("budget_lines")
}

/// Auditable record of every change to the internal budget.
/// Append-only by convention — no edit/delete.
///
/// Scope:
///   - Header-level changes (baseline, contingency, ei_reserve, reallocation):
///     budgetLineId is null; amount is the signed delta at the header.
///   - Line-level changes (line_import, line_manual_adjustment):
///     budgetLineId is set; beforeAmount/afterAmount carry the concrete values;
///     amount = afterAmount - beforeAmount for convenience.
model BudgetAdjustment {
  id             String               @id @default(uuid()) @map("id")
  budgetId       String               @map("budget_id")
  budgetLineId   String?              @map("budget_line_id")
  adjustmentType BudgetAdjustmentType @map("adjustment_type")
  amount         Decimal              @map("amount") @db.Decimal(18, 2)
  beforeAmount   Decimal?             @map("before_amount") @db.Decimal(18, 2)
  afterAmount    Decimal?             @map("after_amount") @db.Decimal(18, 2)
  reason         String               @map("reason")
  approvedBy     String?              @map("approved_by")
  createdBy      String               @map("created_by")
  importBatchId  String?              @map("import_batch_id")
  createdAt      DateTime             @default(now()) @map("created_at")

  budget     ProjectBudget @relation(fields: [budgetId], references: [id], onDelete: Restrict)
  budgetLine BudgetLine?   @relation(fields: [budgetLineId], references: [id], onDelete: Restrict)

  @@index([budgetId, createdAt])
  @@index([budgetLineId, createdAt])
  @@map("budget_adjustments")
}

// ---------------------------------------------------------------------------
// Module 4: Engineer Instruction (EI)
//
// An EI is a field instruction that MAY lead to a Variation Order (VO) or
// Change Order (CO). Upon receipt, Pico Play creates a provisional internal
// budget reserve at 50% of estimated value.
//
// Reserve rules:
//   eiReserveAmount = estimatedValue * reserveRate (default 0.50)
//   Reserve increases INTERNAL budget exposure only — NOT external contract value.
//   When converted to approved VO/CO → release reserve, move delta to revised contract value.
//   When rejected/expired → reverse reserve, audit trail preserved.
// ---------------------------------------------------------------------------

model EngineerInstruction {
  id              String   @id @default(uuid()) @map("id")
  projectId       String   @map("project_id")
  referenceNumber String?  @unique @map("reference_number")
  title           String   @map("title")
  description     String?  @map("description")
  estimatedValue  Decimal  @map("estimated_value") @db.Decimal(18, 2)
  currency        String   @map("currency")
  status          EiStatus @default(received) @map("status")
  /// Reserve rate: fraction of estimatedValue held as internal provision.
  /// Default 0.50 (50%). Configurable per EI for exceptional cases.
  reserveRate     Decimal  @default(0.50) @map("reserve_rate") @db.Decimal(5, 4)
  /// Computed on creation: estimatedValue * reserveRate. Updated if rate changes.
  reserveAmount   Decimal  @map("reserve_amount") @db.Decimal(18, 2)
  /// Set when EI is converted to a VO/CO.
  variationId     String?  @map("variation_id")
  notes           String?  @map("notes")
  createdBy       String   @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Restrict)
  variation Variation? @relation(fields: [variationId], references: [id], onDelete: Restrict)

  @@index([projectId, status])
  @@index([projectId, createdAt])
  @@index([variationId])
  @@map("engineer_instructions")
}

// ---------------------------------------------------------------------------
// Module 5: Controlled sheet import (staging + review queue)
//
// Goal: ingest pre-adoption or manually-prepared spreadsheet data into live
// truth without polluting KPIs / workflows with ungoverned rows. Staging
// tables hold parsed + validated rows; nothing enters live truth until
// commitBatch runs inside a single transaction.
//
// Invariants:
//   - Staging never affects KPIs, dashboards, workflow queues, or registers.
//   - No row enters live truth without explicit commit.
//   - Every committed live record carries importBatchId + importRowId
//     + importedByUserId + importedAt for auditable lineage.
//   - Imported historical IPAs receive origin=imported_historical and are
//     blocked from in-system workflow transitions.
//   - Imported-origin PostingEvents are distinguishable via
//     PostingEvent.origin and never share an idempotencyKey namespace with
//     live events (live: `*-{id}`, imported: `*-imported-{id}`).
// ---------------------------------------------------------------------------

enum ImportType {
  budget_baseline @map("budget_baseline")
  ipa_history     @map("ipa_history")

  @@map("import_type")
}

enum ImportBatchStatus {
  staged          @map("staged")
  validated       @map("validated")
  partially_valid @map("partially_valid")
  committed       @map("committed")
  rejected        @map("rejected")
  cancelled       @map("cancelled")

  @@map("import_batch_status")
}

enum ImportRowStatus {
  pending   @map("pending")
  valid     @map("valid")
  invalid   @map("invalid")
  conflict  @map("conflict")
  committed @map("committed")
  skipped   @map("skipped")

  @@map("import_row_status")
}

model ImportBatch {
  id                         String            @id @default(uuid()) @map("id")
  projectId                  String            @map("project_id")
  importType                 ImportType        @map("import_type")
  sourceFileName             String            @map("source_file_name")
  /// sha256 hex of the uploaded file bytes. Prevents silent duplicate uploads
  /// of the same content for the same project+type.
  sourceFileHash             String            @map("source_file_hash")
  sourceStoragePath          String?           @map("source_storage_path")
  uploadedBy                 String            @map("uploaded_by")
  status                     ImportBatchStatus @default(staged) @map("status")
  /// Row counts by status, totals, mapping stats. Populated at validation time.
  summaryJson                Json              @map("summary_json")
  // Freshness guard — commit refuses if any of these drift from current code/data.
  parserVersion              String?           @map("parser_version")
  validatorSchemaVersion     String?           @map("validator_schema_version")
  referenceDataSnapshotJson  Json?             @map("reference_data_snapshot_json")
  sourceFileHashAtValidation String?           @map("source_file_hash_at_validation")
  validationRanAt            DateTime?         @map("validation_ran_at")
  committedAt                DateTime?         @map("committed_at")
  committedBy                String?           @map("committed_by")
  cancelledAt                DateTime?         @map("cancelled_at")
  cancelledBy                String?           @map("cancelled_by")
  rejectedAt                 DateTime?         @map("rejected_at")
  rejectedBy                 String?           @map("rejected_by")
  rejectReason               String?           @map("reject_reason")
  createdAt                  DateTime          @default(now()) @map("created_at")
  updatedAt                  DateTime          @updatedAt @map("updated_at")

  project Project     @relation(fields: [projectId], references: [id], onDelete: Restrict)
  rows    ImportRow[]

  @@unique([projectId, importType, sourceFileHash])
  @@index([projectId, status])
  @@index([importType, status])
  @@map("import_batches")
}

model ImportRow {
  id                   String          @id @default(uuid()) @map("id")
  batchId              String          @map("batch_id")
  rowNumber            Int             @map("row_number")
  /// Original row values as parsed from the sheet, no normalization.
  rawJson              Json            @map("raw_json")
  /// Normalized / typed shape. Null if parse failed before normalization.
  parsedJson           Json?           @map("parsed_json")
  /// Array of { code, field, message }.
  validationErrorsJson Json            @default("[]") @map("validation_errors_json")
  /// Array of { code, field, message }.
  warningsJson         Json            @default("[]") @map("warnings_json")
  /// Structured conflict record when status=conflict. Shape depends on import type.
  conflictJson         Json?           @map("conflict_json")
  status               ImportRowStatus @default(pending) @map("status")
  committedRecordType  String?         @map("committed_record_type")
  /// Soft FK to the created live record. No cascade — survives record deletion.
  committedRecordId    String?         @map("committed_record_id")
  excludedByUserId     String?         @map("excluded_by_user_id")
  excludedAt           DateTime?       @map("excluded_at")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  batch ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, rowNumber])
  @@index([batchId, status])
  @@map("import_rows")
}

// ---------------------------------------------------------------------------
// IPA adjustment groups (header + field-level children)
//
// Post-commit corrections to IPA records — especially imported historical IPAs
// — must be structurally auditable. One AdjustmentBatch per operator action,
// one AdjustmentField per changed field, and at most one IPA_ADJUSTMENT
// PostingEvent per batch (emitted when monetary fields change).
// ---------------------------------------------------------------------------

model IpaAdjustmentBatch {
  id             String   @id @default(uuid()) @map("id")
  ipaId          String   @map("ipa_id")
  /// 'imported_correction' | 'manual_correction' | 'period_recategorization'
  adjustmentType String   @map("adjustment_type")
  reason         String   @map("reason")
  actorUserId    String   @map("actor_user_id")
  approvedBy     String?  @map("approved_by")
  /// The single IPA_ADJUSTMENT posting event emitted by this batch, if any.
  postingEventId String?  @map("posting_event_id")
  createdAt      DateTime @default(now()) @map("created_at")

  ipa          Ipa                  @relation(fields: [ipaId], references: [id], onDelete: Restrict)
  fields       IpaAdjustmentField[]
  postingEvent PostingEvent?        @relation(fields: [postingEventId], references: [id])

  @@index([ipaId, createdAt])
  @@map("ipa_adjustment_batches")
}

model IpaAdjustmentField {
  id          String   @id @default(uuid()) @map("id")
  batchId     String   @map("batch_id")
  fieldName   String   @map("field_name")
  /// Stringified. Preserves Decimal precision for monetary fields.
  beforeValue String   @map("before_value")
  afterValue  String   @map("after_value")
  createdAt   DateTime @default(now()) @map("created_at")

  batch IpaAdjustmentBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@map("ipa_adjustment_fields")
}
