  id              String    @id @default(uuid())
  quotationId     String    @map("quotation_id")
  itemCatalogId   String?   @map("item_catalog_id")
  rfqItemId       String?   @map("rfq_item_id")
  itemDescription String    @map("item_description")
  quantity        Decimal   @db.Decimal(18, 2)
  unit            String
  unitPrice       Decimal   @map("unit_price") @db.Decimal(18, 2)
  totalPrice      Decimal   @map("total_price") @db.Decimal(18, 2)
  currency        String
  validityDate    DateTime? @map("validity_date")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Restrict)

  @@index([quotationId])
  @@index([itemCatalogId])
  @@map("quotation_line_items")
}

model PurchaseOrder {
  id                    String    @id @default(uuid())
  projectId             String    @map("project_id")
  vendorId              String    @map("vendor_id")
  rfqId                 String?   @map("rfq_id")
  quotationId           String?   @map("quotation_id")
  vendorContractId      String?   @map("vendor_contract_id")
  frameworkAgreementId  String?   @map("framework_agreement_id")
  categoryId            String?   @map("category_id")
  poNumber              String    @unique @map("po_number")
  title                 String
  description           String?
  totalAmount           Decimal   @map("total_amount") @db.Decimal(18, 2)
  currency              String
  deliveryDate          DateTime? @map("delivery_date")
  deliveryAddress       String?   @map("delivery_address")
  paymentTerms          String?   @map("payment_terms")
  hasFrameworkDeviation Boolean   @default(false) @map("has_framework_deviation")
  status                String    @default("draft")
  referenceNumber       String?   @unique @map("reference_number")
  createdBy             String    @map("created_by")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  project          Project             @relation(fields: [projectId], references: [id], onDelete: Restrict)
  vendor           Vendor              @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  items            PurchaseOrderItem[]
  supplierInvoices SupplierInvoice[]
  expenses         Expense[]
  creditNotes      CreditNote[]

  @@index([projectId, status])
  @@index([projectId, vendorId])
  @@index([projectId, createdAt])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String   @id @default(uuid())
  purchaseOrderId String   @map("purchase_order_id")
  itemCatalogId   String?  @map("item_catalog_id")
  itemDescription String   @map("item_description")
  quantity        Decimal  @db.Decimal(18, 2)
  unit            String
  unitPrice       Decimal  @map("unit_price") @db.Decimal(18, 2)
  totalPrice      Decimal  @map("total_price") @db.Decimal(18, 2)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Restrict)

  @@index([purchaseOrderId])
  @@map("purchase_order_items")
}

model SupplierInvoice {
  id              String    @id @default(uuid())
  projectId       String    @map("project_id")
  vendorId        String    @map("vendor_id")
  purchaseOrderId String?   @map("purchase_order_id")
  invoiceNumber   String    @map("invoice_number")
  invoiceDate     DateTime  @map("invoice_date")
  grossAmount     Decimal   @map("gross_amount") @db.Decimal(18, 2)
  vatRate         Decimal   @map("vat_rate") @db.Decimal(5, 4)
  vatAmount       Decimal   @map("vat_amount") @db.Decimal(18, 2)
  totalAmount     Decimal   @map("total_amount") @db.Decimal(18, 2)
  dueDate         DateTime? @map("due_date")
  currency        String
  categoryId      String?   @map("category_id")
  noPOReason      String?   @map("no_po_reason")
  status          String    @default("received")
  createdBy       String    @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Restrict)
  vendor        Vendor         @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: Restrict)
  creditNotes   CreditNote[]

  @@index([projectId, status])
  @@index([projectId, vendorId])
  @@index([projectId, createdAt])
  @@index([purchaseOrderId])
  @@map("supplier_invoices")
}

model Expense {
  id                   String           @id @default(uuid())
  projectId            String           @map("project_id")
  subtype              ExpenseSubtype
  title                String
  description          String?
  amount               Decimal          @db.Decimal(18, 2)
  currency             String
  expenseDate          DateTime         @map("expense_date")
  categoryId           String?          @map("category_id")
  receiptReference     String?          @map("receipt_reference")
  purchaseOrderId      String?          @map("purchase_order_id")
  status               String           @default("draft")
  // ticket-specific
  ticketType           TicketType?      @map("ticket_type")
  travelerName         String?          @map("traveler_name")
  origin               String?
  destination          String?
  travelDate           DateTime?        @map("travel_date")
  returnDate           DateTime?        @map("return_date")
  // accommodation-specific
  guestName            String?          @map("guest_name")
  checkIn              DateTime?        @map("check_in")
  checkOut             DateTime?        @map("check_out")
  hotelName            String?          @map("hotel_name")
  expenseCity          String?          @map("expense_city")
  nightlyRate          Decimal?         @map("nightly_rate") @db.Decimal(18, 2)
  nights               Int?
  // transportation-specific
  vehicleType          String?          @map("vehicle_type")
  transportOrigin      String?          @map("transport_origin")
  transportDestination String?          @map("transport_destination")
  distance             Decimal?         @db.Decimal(10, 2)
  rateType             TransportRateType? @map("rate_type")
  // equipment-specific
  equipmentName        String?          @map("equipment_name")
  equipmentType        String?          @map("equipment_type")
  rentalPeriodFrom     DateTime?        @map("rental_period_from")
  rentalPeriodTo       DateTime?        @map("rental_period_to")
  dailyRate            Decimal?         @map("daily_rate") @db.Decimal(18, 2)
  days                 Int?
  createdBy            String           @map("created_by")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Restrict)
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: Restrict)

  @@index([projectId, subtype, status])
  @@index([projectId, createdAt])
  @@map("expenses")
}

model CreditNote {
  id                String           @id @default(uuid())
  projectId         String           @map("project_id")
  vendorId          String           @map("vendor_id")
  subtype           CreditNoteSubtype
  creditNoteNumber  String           @unique @map("credit_note_number")
  supplierInvoiceId String?          @map("supplier_invoice_id")
  purchaseOrderId   String?          @map("purchase_order_id")
  correspondenceId  String?          @map("correspondence_id")
  amount            Decimal          @db.Decimal(18, 2)
  currency          String
  reason            String
  receivedDate      DateTime         @map("received_date")
  status            String           @default("received")
  createdBy         String           @map("created_by")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  project         Project          @relation(fields: [projectId], references: [id], onDelete: Restrict)
  vendor          Vendor           @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  supplierInvoice SupplierInvoice? @relation(fields: [supplierInvoiceId], references: [id], onDelete: Restrict)
  purchaseOrder   PurchaseOrder?   @relation(fields: [purchaseOrderId], references: [id], onDelete: Restrict)
  correspondence  Correspondence?  @relation(fields: [correspondenceId], references: [id], onDelete: Restrict)

  @@index([projectId, status])
  @@index([projectId, vendorId])
  @@index([projectId, createdAt])
  @@index([supplierInvoiceId])
  @@index([purchaseOrderId])
  @@map("credit_notes")
}
