// ---------------------------------------------------------------------------
// Invoice Collection — records actual money received against tax invoices.
//
// Each row = one payment event. Partial payments produce multiple rows.
// Outstanding = taxInvoice.totalAmount - SUM(invoiceCollections.amount).
// Immutable by operating convention — no edit/delete in v1.
// ---------------------------------------------------------------------------

model InvoiceCollection {
  id             String   @id @default(uuid()) @map("id")
  taxInvoiceId   String   @map("tax_invoice_id")
  amount         Decimal  @map("amount") @db.Decimal(18, 2)
  collectionDate DateTime @map("collection_date")
  paymentMethod  String?  @map("payment_method")
  reference      String?  @map("reference")
  notes          String?  @map("notes")
  recordedBy     String   @map("recorded_by")
  createdAt      DateTime @default(now()) @map("created_at")

  taxInvoice TaxInvoice @relation(fields: [taxInvoiceId], references: [id], onDelete: Restrict)

  @@index([taxInvoiceId])
  @@index([collectionDate])
  @@map("invoice_collections")
}

model Correspondence {
  id                     String                @id @default(uuid()) @map("id")
  projectId              String                @map("project_id")
  subtype                CorrespondenceSubtype @map("subtype")
