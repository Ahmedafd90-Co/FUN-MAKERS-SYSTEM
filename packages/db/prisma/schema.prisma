// ---------------------------------------------------------------------------
// 10. Notifications
// ---------------------------------------------------------------------------

model NotificationTemplate {
  id              String              @id @default(uuid()) @map("id")
  code            String              @unique @map("code")
  channel         NotificationChannel @map("channel")
  subjectTemplate String              @map("subject_template")
  bodyTemplate    String              @map("body_template")
  defaultEnabled  Boolean             @default(true) @map("default_enabled")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  @@map("notification_templates")
}

model Notification {
  id             String              @id @default(uuid()) @map("id")
  userId         String              @map("user_id")
  templateCode   String              @map("template_code")
  idempotencyKey String?             @map("idempotency_key")
  subject        String              @map("subject")
  body           String              @map("body")
  payloadJson    Json                @map("payload_json")
  channel        NotificationChannel @map("channel")
  status         NotificationStatus  @map("status")
  sentAt         DateTime?           @map("sent_at")
  readAt         DateTime?           @map("read_at")
  createdAt      DateTime            @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@unique([idempotencyKey, userId, channel])
  @@index([userId, status, createdAt])
  @@map("notifications")
}

/// Composite PK (userId, templateCode, channel).
model NotificationPreference {
  userId       String              @map("user_id")
  templateCode String              @map("template_code")
  channel      NotificationChannel @map("channel")
  enabled      Boolean             @map("enabled")

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@id([userId, templateCode, channel])
  @@map("notification_preferences")
}

